+import asyncio
+from collections.abc import Awaitable, Callable
+
+from aiogram import Bot
+
+from telegram_bot.config.settings import check_telegram_connection, settings
+
+
+class ConnectionMonitor:
+    def __init__(
+        self,
+        bot: Bot,
+        logger,
+        on_disconnect: Callable[[], Awaitable[None]],
+        interval_sec: int = 30,
+    ) -> None:
+        self.bot = bot
+        self.logger = logger
+        self.on_disconnect = on_disconnect
+        self.interval_sec = interval_sec
+        self._stopped = asyncio.Event()
+
+    async def _notify_admin(self, message: str) -> None:
+        if not settings.admin_chat_id:
+            return
+        try:
+            await self.bot.send_message(chat_id=settings.admin_chat_id, text=message)
+        except Exception as exc:  # noqa: BLE001
+            self.logger.exception("Failed to notify admin about connection issue: %s", exc)
+
+    async def run(self) -> None:
+        while not self._stopped.is_set():
+            try:
+                ok = await check_telegram_connection()
+                if not ok:
+                    self.logger.error("Telegram health-check returned non-OK status")
+                    await self._notify_admin("⚠️ Потеряно соединение с Telegram API. Перезапускаю polling.")
+                    await self.on_disconnect()
+                    return
+            except Exception as exc:  # noqa: BLE001
+                self.logger.exception("Connection monitor failed: %s", exc)
+                await self._notify_admin("⚠️ Ошибка проверки соединения с Telegram API. Перезапускаю polling.")
+                await self.on_disconnect()
+                return
+            await asyncio.sleep(self.interval_sec)
+
+    def stop(self) -> None:
+        self._stopped.set()
 
